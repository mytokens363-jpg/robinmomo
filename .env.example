# Copy to .env (which is gitignored) and fill in. NEVER commit the real .env.

# --- execution safety -----------------------------------------------------
# Master arm switch. Must be exactly "true" for any live order to be sent.
# Leave unset / "false" to stay in dry-run.
LIVE_TRADING=false

# Nominal equity used for dry-run notional logging only. Live mode reads real
# equity from the broker via the proxy.
ROBINMOMO_NOMINAL_EQUITY=10000

# Where runtime state (kill switch, positions, high-water mark) is stored.
ROBINMOMO_STATE=state/robinmomo_state.json

# --- Robinhood Agentic Trading MCP (fill in once the account exists) -------
# Confirm the URL against Robinhood's MCP docs.
RH_MCP_TRADING_URL=https://agent.robinhood.com/mcp/trading

# Path to the gitignored token file holding the OAuth tokens issued by the
# Robinhood browser consent flow. Structure expected by proxy/oauth.py:
#   { "access_token": "...", "refresh_token": "...", "expires_at": 1700000000 }
RH_TOKEN_FILE=secrets/rh_token.json

# --- proxy kill -----------------------------------------------------------
# Set to "1" to hard-block ALL upstream forwarding at the proxy layer.
ROBINMOMO_PROXY_KILL=0
